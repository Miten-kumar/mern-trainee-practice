{
  "compilerOptions": {

    "target": "ES2022",

    "module": "NodeNext",

    "moduleResolution": "NodeNext",

    "rootDir": "./",

    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "types": [
      "node",
      "jest"
    ]

  },

  "include": [
    "src",
    "tests",
    "prisma"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}