{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "resolveJsonModule": true,

    "noUnusedLocals": true,
    "noUnusedParameters": true,

    "sourceMap": true,
    "declaration": true,

    "types": [
      "node",
      "jest"
    ]
  },

  "include": [
    "src/**/*.ts",
    "tests/**/*.ts"
  ],

  "exclude": [
    "node_modules",
    "dist",
    "tests"
  ]
}